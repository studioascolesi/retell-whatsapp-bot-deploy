# ============================================
# RETELL AI - CONFIGURAZIONE
# ============================================
RETELL_API_KEY=your_retell_api_key_here
RETELL_AGENT_ID=your_retell_agent_id_here
RETELL_LLM_ID=your_retell_llm_id_here

# ============================================
# WHATSAPP WEB - CONFIGURAZIONE
# ============================================
# Il bot usa whatsapp-web.js. Non servono token API.
# Per collegare il bot, scansiona il QR code all'avvio via /setup

# ============================================
# CONFIGURAZIONE SERVER
# ============================================
PORT=3000

# ============================================
# DESTINATARIO MESSAGGI
# ============================================
# Numero di telefono destinatario (senza +)
# Esempio: 391234567890
WHATSAPP_RECIPIENT=numero_destinatario

# Opzioni messaggio
INCLUDE_TRANSCRIPTION=true
INCLUDE_SENTIMENT=true
INCLUDE_ACTION_ITEMS=true
